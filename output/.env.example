# ============================================================
# Supermarket Management System — Variabili d'ambiente
# ============================================================
# Copia questo file in .env e modifica con le tue credenziali
#   cp .env.example .env

# ── DATABASE POSTGRESQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supermarket_db
DB_USER=supermarket_user
DB_PASSWORD=supermarket_pass

# URL completo (usato come fallback se le variabili sopra non bastano)
DATABASE_URL=postgresql://supermarket_user:supermarket_pass@localhost:5432/supermarket_db

# ── ADMIN DI DEFAULT ────────────────────────────────────────
# Queste credenziali vengono usate al primo avvio per creare l'admin
ADMIN_EMAIL=robby@gmail.com

# Hash bcrypt di "robby@123" — non modificare a meno di cambiare password
ADMIN_PASSWORD_HASH=$2b$12$lbQ7.nODQxFqx4gDdW7st.jOq3LpeBWzvPy8FwKXo2Yl.sl7BNcSa

# ── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=INFO
