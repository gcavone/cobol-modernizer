# ============================================================
# COBOL Modernizer — Variabili d'ambiente
# ============================================================
# Copia questo file in .env e inserisci le tue chiavi API
#   cp .env.example .env

# ── MODELLO LLM ─────────────────────────────────────────────
# Scegli uno dei tre provider e inserisci la chiave API.
# Lascia vuoti gli altri.

# Groq (gratuito, consigliato per iniziare)
# https://console.groq.com/
GROQ_API_KEY=

# Mistral (gratuito con limiti)
# https://console.mistral.ai/
MISTRAL_API_KEY=

# Anthropic Claude (a pagamento)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── MLFLOW (opzionale) ──────────────────────────────────────
# Lascia vuoto per usare il tracking locale (default)
MLFLOW_TRACKING_URI=
